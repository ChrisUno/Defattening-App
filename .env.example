# ─── Database ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=defattening
DB_USER=defattening
DB_PASSWORD=defattening

# ─── Server ─────────────────────────────────────
PORT=3001
NODE_ENV=development
SESSION_SECRET=change-me-in-production  # REQUIRED in production

# ─── CORS (production only) ────────────────────
# CORS_ORIGIN=https://your-domain.com  # Omit for same-origin (single-container)

# ─── Microsoft Entra ID ────────────────────────
ENTRA_TENANT_ID=your-tenant-id
ENTRA_API_CLIENT_ID=your-api-client-id

# ─── Frontend (Vite build-time) ────────────────
VITE_ENTRA_TENANT_ID=your-tenant-id
VITE_ENTRA_CLIENT_ID=your-spa-client-id
VITE_ENTRA_API_SCOPE=api://your-api-client-id/access_as_user
